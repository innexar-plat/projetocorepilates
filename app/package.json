{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --coverage --coverageReporters=text-summary",
    "test:integration": "jest src/integration --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --project tsconfig.json -e 'require(\"./prisma/seed\")'"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@swc/helpers": "^0.5.20",
    "bcryptjs": "^3.0.3",
    "minio": "^8.0.7",
    "nanoid": "^5.1.7",
    "next": "14.2.35",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.8.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.6.0",
    "react": "^18",
    "react-dom": "^18",
    "react-email": "^5.2.10",
    "resend": "^6.9.4",
    "stripe": "^21.0.1",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "ts-node --esm prisma/seed.ts"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pino": "^7.0.4",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  }
}
